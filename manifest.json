{
  "manifest_version": 3,
  "name": "TypoSwitch",
  "version": "1.0.0",
  "description": "Instantly fix Hebrew/English keyboard layout mistakes. Convert mistyped text with a keyboard shortcut, popup, or right-click menu.",
  "permissions": ["storage", "contextMenus"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "TypoSwitch",
    "default_popup": "popup.html"
  },
  "options_page": "settings.html",
  "commands": {
  "fix-layout": {
    "suggested_key": {
      "default": "Ctrl+Shift+Y"
    },
    "description": "Fix selected text or the last typed word"
  }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
