{
  "manifest_version": 3,
  "name": "TypoSwitch",
  "version": "1.0.0",
  "description": "Fix Hebrew/English keyboard layout mistakes in text fields.",
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "TypoSwitch",
    "default_popup": "popup.html"
  },
  "commands": {
  "fix-layout": {
    "suggested_key": {
      "default": "Ctrl+Shift+Y"
    },
    "description": "Fix selected text or the last typed word"
  }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["storage", "contextMenus"],
  "options_page": "settings.html"
}